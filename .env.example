# .env.example — Template for required environment variables.
# Copy this to .env and fill in your real values.
# NEVER commit the .env file — it is in .gitignore.

# ── AI Reply (Groq) ───────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
# Without this key, the /ticket/reply endpoint still works but returns
# a static fallback reply instead of an AI-generated one.
GROQ_API_KEY=your_groq_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Optional: override the SQLite database path (default: ./support.db)
# For production, you could switch to PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///./support.db
